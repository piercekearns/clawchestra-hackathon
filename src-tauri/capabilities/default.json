{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Clawchestra",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "fs:default",
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "/tmp/**" }, { "path": "/private/tmp/**" }]
    },
    "websocket:default",
    "window-state:default",
    "pty:default"
  ]
}
